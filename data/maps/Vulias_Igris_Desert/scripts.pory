mapscripts Vulias_Igris_Desert_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: IgrisDesert_OnTransition_SetState
    MAP_SCRIPT_ON_FRAME_TABLE [
        VAR_ZED_STORY_TRACKER, 23: IgrisDesert_FoundChildWarpedOutside
        VAR_IGRIS_DIGDUNGEON_DOHOP, 1: IgrisDesert_SandHoleSpitOutOnEntry
    ]
}

// Player jumps two blocks up if entering from dig dungeon buffer
script IgrisDesert_SandHoleSpitOutOnEntry {
    setvar(VAR_IGRIS_DIGDUNGEON_DOHOP, 0)
    lock
    applymovement(OBJ_EVENT_ID_PLAYER, moves(jump_2_up, jump_up, face_down))
    waitmovement
    if (!flag(FLAG_LEAVING_IGRIS_UNDER_SOUTH)) {
        msgbox("You were thrown out back into the
                Desert!
                
                Perhaps if you could {COLOR RED}Dig{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} better, you
                could find yourself somewhere else!", MSGBOX_SIGN)
    } else {
       msgbox("You were thrown out back into the
                Desert!", MSGBOX_SIGN) 
        clearflag(FLAG_LEAVING_IGRIS_UNDER_SOUTH)
    }
    
    waitmessage
    release
    end
}

// Hide hidden-by-defaults, etc
script IgrisDesert_OnTransition_SetState {
    if (var(VAR_ZED_STORY_TRACKER) < 23) {
        setflag(FLAG_RUVELPYRAMIDEXT_LOSTKID)
    }
    if (var(VAR_ZED_STORY_TRACKER) < 21) {
        setflag(FLAG_RUVELPYRAMIDEXT_LOSTKIDMOM2)
        setflag(FLAG_RUVELPYRAMIDEXT_LOSTKIDMOM3)
        setflag(FLAG_RUVELPYRAMIDEXT_JORDAN)
        setflag(FLAG_PALENTOPOKECENTER_JORDAN01)
    }
    setvar(VAR_IGRIS_DIGBUFFER_DOTELE, 0)
    clearflag(FLAG_ENTERING_IGRISUNDER_NORTH)
}

// Signs and Items

// Palento Village
script IgrisDesert_EventScript_PalentoVillageSign{
    lockall
    msgbox("{RIGHT_ARROW} Palento Village")
    releaseall
}

// Krokorok angry jump and smack
script IgrisDesert_EventScript_AngryKrokorok {
    lock
    faceplayer
    msgbox("The Krokorok looks extremely angry, it
            seems to be protecting it's young!")
    waitmessage
    playmoncry(SPECIES_KROKOROK, CRY_MODE_NORMAL)
    msgbox("V-V Vruuu")
    waitmoncry
    applymovement(OBJ_EVENT_ID_PLAYER, moves(jump_down,face_up))
    playse(SE_BIKE_HOP)
    waitmovement
    msgbox("You barely jump out of the way of a Bite
            attack! Better steer clear!
    ")
    waitmessage
    release
    end
}

