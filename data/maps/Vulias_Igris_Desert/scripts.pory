// Trigger mother running out of Pyramid
script IgrisDesert_EventScript_MotherRunningOutPyramid {
    lock
    applymovement(OBJ_EVENT_ID_PLAYER, moves(emote_exclamation_mark))
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(emote_exclamation_mark))
    playse(SE_PIN)
    applymovement(IGRIS_LOSTCHILD_MOM, moves(walk_faster_down * 5, walk_in_place_fast_down))
    waitmovement
    applymovement(IGRIS_LOSTCHILD_MOM, moves(emote_exclamation_mark))
    delay(60)
    msgbox("{COLOR GREEN}Distressed Mother: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}My little girl! They
            were taken by a {COLOR RED}Pokemon{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} in the Pyramid!
            My goodness, someone please help!")
    waitmessage
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_right, face_left))
    delay(20)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(walk_right, face_left))
    waitmovement
    setobjectxy(RUVELPYRAMIDEXT_GENTLEMAN, 13, 20)
    applymovement(RUVELPYRAMIDEXT_GENTLEMAN, moves(walk_fast_up * 5))
    waitmovement
    msgbox("{COLOR GREEN}Gentleman: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}A lost child you say?
            I shall rush to the Pokemon Center at
            once for more assistance!")
    waitmessage
    applymovement(RUVELPYRAMIDEXT_GENTLEMAN, moves(walk_fast_down * 5))
    waitmovement
    removeobject(RUVELPYRAMIDEXT_GENTLEMAN)
    applymovement(IGRIS_LOSTCHILD_MOM, moves(walk_faster_down, face_right))
    waitmovement
    msgbox("{COLOR GREEN}Distressed Mother: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Please, try to find
            my little girl! She was taken into the
            closed off areas of the Pyramid by an
            unknown Pokemon!
            
            There are all manner of deadly traps
            within...oh my poor child!")
    waitmessage
    applymovement(IGRIS_LOSTCHILD_MOM, moves(walk_down * 3))
    waitmovement
    removeobject(IGRIS_LOSTCHILD_MOM)
    addobject(IGRIS_LOSTCHILD_MOM_2)
    clearflag(FLAG_RUVELPYRAMIDEXT_LOSTKIDMOM2)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_down))
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(face_up))
    msgbox("{COLOR GREEN}Jordan: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Well, another reason to check
            out the Pyramid! Although, I suppose
            saving a child does come first.
            
            Let's not waste any time!")
    waitmessage
    startquest(2)
    setvar(VAR_ZED_STORY_TRACKER, 21)
    release
    end
}

// Mom waiting for kid to be saved
script IgrisDesert_EventScript_DistressedMomWaiting {
    lock
    faceplayer
    msgbox("{COLOR GREEN}Distressed Mother: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Please don't
            tarry, who knows what my poor child
            could be going through right now?
            
            Oh no...
            
            The woman breaks down crying. Better
            get a move on!")
    waitmessage
    release
    end
}

// Player warped back out after finding the lost kid
script IgrisDesert_FoundChildWarpedOutside {
    setvar(VAR_ZED_STORY_TRACKER, 24)
    delay(30)
    msgbox("{COLOR GREEN}Happy Mother: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Oh thank goodness you're
            okay my sweet! I've been losing my mind
            over you!")
    waitmessage
    msgbox("{COLOR GREEN}Found Child: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Those nice people saved
            me! That mean Pokemon took me to a dark
            scary room and they saved me!")
    waitmessage
    applymovement(IGRIS_LOSTCHILD_MOM_3, moves(walk_right, face_up))
    waitmovement
    msgbox("{COLOR GREEN}Happy Mother: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}I could never repay
            you for what you've done for me and
            my child. The least I can do is give
            you each one of these")
    waitmessage
    giveitem(ITEM_NUGGET, 1)
    waitmessage
    playse(MUS_OBTAIN_ITEM)
    msgbox("Jordan recieved a Nugget!
    
            He put it away in his Bag.", MSGBOX_SIGN)
    waitmessage
    waitse
    applymovement(IGRIS_LOSTCHILD_MOM_3, moves(walk_left, face_up))
    msgbox("{COLOR GREEN}Happy Mother: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Now, come along, and stay
            very close!")
    waitmessage
    msgbox("{COLOR GREEN}Found Child: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}Yes mommy!")
    applymovement(IGRIS_LOSTCHILD_MOM_3, moves(walk_down * 9))
    applymovement(IGRIS_LOSTKID_FOUND, moves(walk_down * 9))
    waitmovement
    removeobject(IGRIS_LOSTKID_FOUND)
    removeobject(IGRIS_LOSTCHILD_MOM_3)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_right))
    applymovement(IGRIS_JORDAN_AFTERKIDSAVED, moves(face_left))
    msgbox("{COLOR GREEN}Jordan: {COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}That was a handful! I'm glad we
            were able to save that kid. Not to
            mention, we were able to go into
            the forbidden areas of the
            Pyramid!
            
            I wonder if they will let us go back
            in now?
            
            Well, I think I've had enough
            Pyramid spelunking for today, I'm
            going to go rest up at
            Palento Village for a bit.
            
            You can go on ahead, I'll catch up!
            See you later {PLAYER}!")
    waitmessage
    applymovement(IGRIS_JORDAN_AFTERKIDSAVED, moves(walk_down * 9))
    waitmovement
    destroyfollowernpc
    clearflag(FLAG_PALENTOPOKECENTER_JORDAN01)
    delay(30)
    setvar(VAR_ZED_STORY_TRACKER, 24)
    removeobject(IGRIS_JORDAN_AFTERKIDSAVED)
    completequest(2)
    release
    end
}