// Below two trigger `IgrisDesert_EventScript_MotherRunningOutPyramid` if player
// approached from the side
script IgrisDesert_EventScript_MotherRunningOutPyramid_TriggerLeft {
    lock
    applymovement(OBJ_EVENT_ID_PLAYER, moves(walk_right, face_up))
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_right, face_up))
    waitmovement
    goto(IgrisDesert_EventScript_MotherRunningOutPyramid)
}

script IgrisDesert_EventScript_MotherRunningOutPyramid_TriggerCenter {
    lock
    applymovement(OBJ_EVENT_ID_PLAYER, moves(walk_up))
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_up))
    waitmovement
    goto(IgrisDesert_EventScript_MotherRunningOutPyramid)
}

script IgrisDesert_EventScript_MotherRunningOutPyramid_TriggerRight {
    lock
    applymovement(OBJ_EVENT_ID_PLAYER, moves(walk_left, face_up))
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(walk_left, face_up))
    waitmovement
