mapscripts ZED_LittlerootTown_Test01_1F_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
        VAR_ZED_STORY_TRACKER, 0: LittlerootTown_EventScript_JordanAwakenStart
        VAR_ZED_STORY_TRACKER, 6: SawgrassVillage_AwakenAfterRoute110
    ]
}

// Jordan wakes the player
script LittlerootTown_EventScript_JordanAwakenStart {
    lock
    // Jordan walk to player in bed
    playbgm(MUS_ENCOUNTER_MAY, 0)
    applymovement(JordanInHome, moves(
        emote_exclamation_mark
    ))
    playse(SE_PIN)
    delay(60)
    applymovement(JordanInHome, moves(
        walk_up,
        walk_left * 4,
        walk_up,
        walk_left
    ))
    waitmovement
    setspeaker("Jordan")
    msgbox("Are you okay? You were tossing and
            turning for the past few minutes.
            Anyways, I bet you're ready to get
            going, those feature matches are the
            coolest thing in the world!
            
            Like I said yesterday, you absolutely
            must check out {COLOR RED}The Palladium{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} in
            Gerbon Town, just east of here.
            
            I'm tuckered out today, but I'll go
            to the other {COLOR RED}Battle Stadiums{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} with you
            tomorrow!"
    )
    waitmessage
    closemessage
    // Jordan walk back to table from bed
    applymovement(JordanInHome, moves(
        walk_right,
        walk_down,
        walk_right * 4,
        walk_down,
        face_left
    ))
    waitmovement

    // Start main story quest
    startquest(0)

    // Player arrived at bed after choosing starter
    setvar(VAR_ZED_STORY_TRACKER, 1)
    fadedefaultbgm
    release
}

// Jordan remembers to tell you something before you leave for first time
script LittlerootTown_EventScript_JordanRememberTrainers{
    lock
    applymovement(JordanInHome, moves(
        emote_exclamation_mark
    ))
    delay(60)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_right))
    applymovement(JordanInHome, moves(
        walk_up,
        walk_left * 3,
        walk_down * 2,
        face_left
    ))
    waitmovement
    setspeaker("Jordan")
    msgbox("Sorry, I forgot to tell you!
            The trainers around here don't mess
            around, you'll face a pretty tough
            challenge!
            
            I recommend you stick to the south side
            of Route 101 to avoid them, but that's
            up to you!
            
            If you decide to battle them, these will
            help out. Catch!")
    waitmessage
    closemessage
    giveitem(ITEM_POTION, 10)
    giveitem(ITEM_FULL_HEAL, 5)
    msgbox("Those should cover our meal in
            Woltia City, that you paid for.
            
            ...
            
            Alright, that was quite a bit more
            expensive I'll admit it. That should
            be at least half!
            
            Anyways, don't go to hard on your
            Pokemon, those trainers are really
            tough! Good luck!")
    waitmessage
    closemessage
    applymovement(JordanInHome, moves(
        walk_up * 2,
        walk_right * 3,
        walk_down,
        face_left
    ))
    waitmovement
    setvar(VAR_JORDAN_WARNED_TRAINERS, 1)
    setrespawn(HEAL_LOCATION_LITTLEROOT_TOWN)
    release
    end
}

// Awoken in house after reaching end of Route 110
script SawgrassVillage_AwakenAfterRoute110 {
    lock
    setvar(VAR_ZED_STORY_TRACKER, 7)
    // Jordan walk to player in bed
    playbgm(MUS_ENCOUNTER_MAY, 0)
    applymovement(JordanInHome, moves(
        emote_exclamation_mark
    ))
    playse(SE_PIN)
    delay(60)
    applymovement(JordanInHome, moves(
        walk_up,
        walk_left * 4,
        walk_up,
        walk_left
    ))
    waitmovement
    setspeaker("Jordan")
    msgbox("Good morning {PLAYER}! You better
            have gotten good sleep, because today,
            we're gonna have great battles!
            
            The tournament to decide the next 
            {COLOR RED}Representative Trainer{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} for {COLOR RED}The
            Palladium{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY} is starting today! I'm going
            to make my way over there.
            
            You can take your time, do a bit of
            training if you want! Meet me at the
            entrance to {COLOR RED}The Palladium!{COLOR DARK_GRAY}{SHADOW LIGHT_GRAY}"
    )
    waitmessage
    applymovement(JordanInHome, moves(walk_down * 3, walk_left, walk_down))
    waitmovement
    playse(SE_DOOR)
    setflag(FLAG_JORDANINHOME)
    removeobject(JordanInHome)
    clearflag(FLAG_GERBON_TOWN_BLOCKERS)
    addobject(GERBON_PALLADIUM_BLOCKER_1)
    addobject(GERBON_PALLADIUM_BLOCKER_2)
    clearflag(FLAG_GERBON_JORDAN_TOURNEY_OUTSIDE)
    waitse
    fadedefaultbgm
    delay(30)
    questupdated(0)
    release
    end
}
